{
  "version": 1,
  "defaults": {
    "dailyTargetEn": 12,
    "batchSize": 6,
    "catchupMaxPerRun": 72,
    "minScore": 98,
    "minWords": 3000,
    "syndicate": true,
    "templateFirst": true
  },
  "sites": [
    {
      "id": "wreckmatch",
