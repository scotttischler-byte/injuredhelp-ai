{
  "name": "injuredhelp.ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "generate:blog": "node scripts/generate-content.mjs blog",
    "generate:geo": "node scripts/generate-content.mjs geo",
    "export:geo": "npx tsx scripts/export-priority-geo-markdown.ts",
    "generate:prompts": "node scripts/generate-ai-prompt-library.mjs",
    "monitor:ai-citations": "node scripts/ai-citation-monitor.mjs --limit 25",
    "monitor:ai-citations:live": "node scripts/ai-citation-monitor.mjs --limit 15 --live",
    "indexing:notify": "python scripts/indexing_accelerator.py",
    "indexing:dry-run": "python scripts/indexing_accelerator.py --dry-run"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.3",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
