{
  "name": "injuredhelp.ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "fix:blog-posts": "python3 scripts/fix_blog_posts.py",
    "audit:blog": "python3 scripts/blog_quality_gate.py",
    "gate:blog": "python3 scripts/blog_quality_gate.py --min-score 95",
    "upgrade:blog-claude": "python3 scripts/upgrade_blogs_claude.py --limit 15 --min-score 95",
    "upgrade:blog-all": "python3 scripts/upgrade_blogs_claude.py --all --min-score 95 --sleep 3",
    "generate:blog-covers": "node scripts/generate-blog-cover-assets.mjs",
    "generate:blog-covers:all": "node scripts/generate-blog-cover-assets.mjs --force",
    "build:cover-photo-pool": "node scripts/build-cover-photo-pool.mjs",
    "generate:blog": "node scripts/generate-content.mjs blog",
    "generate:geo": "node scripts/generate-content.mjs geo",
    "export:geo": "npx tsx scripts/export-priority-geo-markdown.ts",
    "generate:prompts": "node scripts/generate-ai-prompt-library.mjs",
    "monitor:ai-citations": "node scripts/ai-citation-monitor.mjs --limit 25",
    "monitor:ai-citations:live": "node scripts/ai-citation-monitor.mjs --limit 15 --live",
    "indexing:notify": "python3 scripts/indexing_accelerator.py",
    "indexing:batch-new": "python3 scripts/indexing_accelerator.py --since-commit 35b12f3",
    "indexing:dry-run": "python3 scripts/indexing_accelerator.py --dry-run",
    "indexing:dry-run:batch": "python3 scripts/indexing_accelerator.py --dry-run --since-commit 35b12f3",
    "indexing:verify-key": "python3 scripts/indexing_accelerator.py --verify-key"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.3",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
